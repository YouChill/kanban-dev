@using KanbanApp.Models
@using KanbanApp.Models.Enums
@using KanbanApp.Services.Interfaces
@inject ITaskService TaskService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject INotificationService Notify

<MudDialog Class="task-detail-dialog">
    <DialogContent>
        @if (_loading)
        {
            <div class="task-detail__loading">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_task is null)
        {
            <MudText Typo="Typo.body1" Color="Color.Error">Nie znaleziono zadania.</MudText>
        }
        else
        {
            <div class="task-detail__layout">
                <div class="task-detail__left">
                    @if (_editingTitle)
                    {
                        <MudTextField @bind-Value="_titleValue"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      AutoFocus="true"
                                      Class="task-detail__title-input"
                                      OnBlur="SaveTitle"
                                      OnKeyDown="HandleTitleKeyDown" />
                    }
                    else
                    {
                        <MudText Typo="Typo.h5"
                                 Class="task-detail__title task-detail__title--editable"
                                 @onclick="StartEditingTitle">
                            @_task.Title
                        </MudText>
                    }

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Opis</MudText>
                        <MudTextField @bind-Value="_descriptionValue"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Placeholder="Dodaj opis..."
                                      Immediate="true"
                                      DebounceInterval="500"
                                      OnDebounceIntervalElapsed="SaveDescription"
                                      Class="task-detail__description-input" />
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Checklista</MudText>
                        @{
                            var done = _task.ChecklistItems.Count(c => c.IsDone);
                            var total = _task.ChecklistItems.Count;
                        }
                        @if (total > 0)
                        {
                            <div class="task-detail__checklist-progress">
                                <div class="task-detail__checklist-progress-bar">
                                    <div class="task-detail__checklist-progress-fill"
                                         style="width: @((double)done / total * 100)%"></div>
                                </div>
                                <MudText Typo="Typo.caption" Class="task-detail__checklist-progress-text">
                                    @done z @total
                                </MudText>
                            </div>
                        }
                        @foreach (var item in _task.ChecklistItems)
                        {
                            var capturedItem = item;
                            <div class="task-detail__checklist-item">
                                <MudIconButton Icon="@(capturedItem.IsDone ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                                               Size="Size.Small"
                                               Color="@(capturedItem.IsDone ? Color.Success : Color.Default)"
                                               OnClick="() => ToggleChecklistItem(capturedItem)" />
                                @if (_editingChecklistItemId == capturedItem.Id)
                                {
                                    <MudTextField @bind-Value="_editingChecklistText"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  AutoFocus="true"
                                                  Class="task-detail__checklist-edit-input"
                                                  OnKeyDown="(e) => HandleChecklistEditKeyDown(e, capturedItem)" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2"
                                             Class="@($"task-detail__checklist-text {(capturedItem.IsDone ? "task-detail__checklist-done" : "")}")"
                                             @onclick="() => StartEditingChecklistItem(capturedItem)">
                                        @capturedItem.Text
                                    </MudText>
                                }
                                <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                               Size="Size.Small"
                                               Class="task-detail__checklist-delete"
                                               OnClick="() => DeleteChecklistItem(capturedItem)" />
                            </div>
                        }
                        <div class="task-detail__checklist-add">
                            <MudTextField @bind-Value="_newChecklistText"
                                          Placeholder="Dodaj element..."
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          OnKeyDown="HandleNewChecklistKeyDown"
                                          Class="task-detail__checklist-add-input" />
                        </div>
                    </div>
                </div>

                <div class="task-detail__right">
                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Priorytet</MudText>
                        <MudSelect T="Priority"
                                   Value="_task.Priority"
                                   ValueChanged="SavePriority"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="task-detail__priority-select">
                            @foreach (Priority p in Enum.GetValues<Priority>())
                            {
                                <MudSelectItem Value="@p">@GetPriorityLabel(p)</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Termin</MudText>
                        <MudDatePicker Date="_dueDateValue"
                                       DateChanged="SaveDueDate"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Placeholder="Wybierz datę..."
                                       Clearable="true"
                                       DateFormat="dd MMMM yyyy"
                                       Class="task-detail__date-picker" />
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Tagi</MudText>
                        @if (_task.Tags.Count > 0)
                        {
                            <div class="task-detail__tags">
                                @foreach (var tag in _task.Tags)
                                {
                                    var capturedTag = tag;
                                    <MudChip T="string" Size="Size.Small"
                                             OnClose="() => RemoveTag(capturedTag)"
                                             Style="@($"background-color: {(capturedTag.Color ?? "#6366f1")}20; color: {(capturedTag.Color ?? "#6366f1")}; font-weight: 600;")">
                                        @capturedTag.Name
                                    </MudChip>
                                }
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--text-secondary); font-style: italic;">
                                Brak tagów
                            </MudText>
                        }

                        @if (!_showTagMenu)
                        {
                            <MudButton Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Size="Size.Small"
                                       Class="task-detail__add-tag-btn"
                                       OnClick="OpenTagMenu">
                                Dodaj tag
                            </MudButton>
                        }
                        else
                        {
                            <div class="task-detail__tag-menu">
                                @{
                                    var unassigned = _allTags.Where(t => !_task.Tags.Any(tt => tt.Id == t.Id)).ToList();
                                }
                                @if (unassigned.Count > 0)
                                {
                                    <div class="task-detail__tag-list">
                                        @foreach (var tag in unassigned)
                                        {
                                            var capturedTag = tag;
                                            <button class="task-detail__tag-option" @onclick="() => AddTag(capturedTag)">
                                                <span class="task-detail__tag-option-dot" style="background-color: @(capturedTag.Color ?? "#6366f1")"></span>
                                                @capturedTag.Name
                                            </button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Style="color: var(--text-secondary); padding: 4px 0;">
                                        Wszystkie tagi przypisane
                                    </MudText>
                                }

                                <div class="task-detail__tag-divider"></div>

                                @if (!_showCreateTag)
                                {
                                    <button class="task-detail__tag-option task-detail__tag-option--create" @onclick="() => _showCreateTag = true">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                        Utwórz nowy tag
                                    </button>
                                }
                                else
                                {
                                    <div class="task-detail__tag-create">
                                        <MudTextField @bind-Value="_newTagName"
                                                      Placeholder="Nazwa tagu..."
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Class="task-detail__tag-name-input" />
                                        <div class="task-detail__tag-colors">
                                            @foreach (var color in _tagColorPalette)
                                            {
                                                var c = color;
                                                <button class="task-detail__tag-color-swatch @(_newTagColor == c ? "task-detail__tag-color-swatch--active" : "")"
                                                        style="background-color: @c"
                                                        @onclick="() => _newTagColor = c"></button>
                                            }
                                        </div>
                                        <div class="task-detail__tag-create-actions">
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="@string.IsNullOrWhiteSpace(_newTagName)"
                                                       OnClick="CreateAndAddTag">
                                                Utwórz
                                            </MudButton>
                                            <MudButton Variant="Variant.Text"
                                                       Size="Size.Small"
                                                       OnClick="CancelCreateTag">
                                                Anuluj
                                            </MudButton>
                                        </div>
                                    </div>
                                }

                                <div class="task-detail__tag-divider"></div>
                                <button class="task-detail__tag-option task-detail__tag-option--close" @onclick="CloseTagMenu">
                                    Zamknij
                                </button>
                            </div>
                        }
                    </div>

                    <div class="task-detail__divider"></div>

                    <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                               StartIcon="@Icons.Material.Outlined.Delete" OnClick="HandleDelete">
                        Usuń zadanie
                    </MudButton>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Zamknij</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int TaskId { get; set; }

    private TaskItem? _task;
    private bool _loading = true;

    // Editable field state
    private bool _editingTitle;
    private string _titleValue = string.Empty;
    private string? _descriptionValue;
    private DateTime? _dueDateValue;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            if (_task is not null)
            {
                _titleValue = _task.Title;
                _descriptionValue = _task.Description;
                _dueDateValue = _task.DueDate;
            }
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się załadować zadania");
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Title editing ──

    private void StartEditingTitle()
    {
        _titleValue = _task!.Title;
        _editingTitle = true;
    }

    private async Task SaveTitle()
    {
        _editingTitle = false;
        if (_task is null) return;

        var trimmed = _titleValue?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || trimmed == _task.Title)
        {
            _titleValue = _task.Title;
            return;
        }

        _task.Title = trimmed;
        _titleValue = trimmed;
        await PersistTask();
    }

    private async Task HandleTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveTitle();
        }
        else if (e.Key == "Escape")
        {
            _titleValue = _task!.Title;
            _editingTitle = false;
        }
    }

    // ── Description editing (debounced) ──

    private async Task SaveDescription(string value)
    {
        if (_task is null) return;
        _task.Description = value;
        await PersistTask();
    }

    // ── Priority editing ──

    private async Task SavePriority(Priority newPriority)
    {
        if (_task is null || _task.Priority == newPriority) return;
        _task.Priority = newPriority;
        await PersistTask();
    }

    // ── Due date editing ──

    private async Task SaveDueDate(DateTime? newDate)
    {
        if (_task is null) return;
        _dueDateValue = newDate;
        _task.DueDate = newDate;
        await PersistTask();
    }

    // ── Checklist ──

    private string _newChecklistText = string.Empty;
    private int? _editingChecklistItemId;
    private string _editingChecklistText = string.Empty;

    private async Task ToggleChecklistItem(ChecklistItem item)
    {
        item.IsDone = !item.IsDone;
        try
        {
            await TaskService.UpdateChecklistItemAsync(item);
        }
        catch (Exception)
        {
            item.IsDone = !item.IsDone;
            Notify.ShowError("Nie udało się zaktualizować elementu checklisty");
        }
    }

    private void StartEditingChecklistItem(ChecklistItem item)
    {
        _editingChecklistItemId = item.Id;
        _editingChecklistText = item.Text;
    }

    private async Task SaveChecklistItemText(ChecklistItem item)
    {
        _editingChecklistItemId = null;
        var trimmed = _editingChecklistText?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || trimmed == item.Text)
            return;

        item.Text = trimmed;
        await TaskService.UpdateChecklistItemAsync(item);
    }

    private async Task HandleChecklistEditKeyDown(KeyboardEventArgs e, ChecklistItem item)
    {
        if (e.Key == "Enter")
        {
            await SaveChecklistItemText(item);
        }
        else if (e.Key == "Escape")
        {
            _editingChecklistText = item.Text;
            _editingChecklistItemId = null;
        }
    }

    private async Task DeleteChecklistItem(ChecklistItem item)
    {
        try
        {
            await TaskService.DeleteChecklistItemAsync(item.Id);
            _task!.ChecklistItems.Remove(item);
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się usunąć elementu checklisty");
        }
    }

    private async Task HandleNewChecklistKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newChecklistText))
        {
            try
            {
                var newItem = await TaskService.AddChecklistItemAsync(_task!.Id, _newChecklistText.Trim());
                // EF Core fix-up adds to _task.ChecklistItems automatically;
                // guard against environments where it doesn't
                if (!_task.ChecklistItems.Any(c => c.Id == newItem.Id))
                    _task.ChecklistItems.Add(newItem);
                _newChecklistText = string.Empty;
            }
            catch (Exception)
            {
                Notify.ShowError("Nie udało się dodać elementu checklisty");
            }
        }
    }

    // ── Tags ──

    private List<Tag> _allTags = [];
    private bool _showTagMenu;
    private bool _showCreateTag;
    private string _newTagName = string.Empty;
    private string _newTagColor = "#6366f1";

    private static readonly string[] _tagColorPalette =
    [
        "#3b82f6", "#6366f1", "#8b5cf6", "#ec4899",
        "#16a34a", "#d97706", "#ef4444", "#0891b2",
        "#84cc16", "#f97316"
    ];

    private async Task OpenTagMenu()
    {
        _allTags = await TaskService.GetAvailableTagsAsync();
        _showTagMenu = true;
        _showCreateTag = false;
    }

    private void CloseTagMenu()
    {
        _showTagMenu = false;
        _showCreateTag = false;
        _newTagName = string.Empty;
        _newTagColor = "#6366f1";
    }

    private async Task AddTag(Tag tag)
    {
        if (_task is null) return;

        try
        {
            var success = await TaskService.AddTagToTaskAsync(_task.Id, tag.Id);
            if (success)
            {
                if (!_task.Tags.Any(t => t.Id == tag.Id))
                    _task.Tags.Add(tag);
                Notify.ShowSuccess($"Dodano tag \"{tag.Name}\"");
            }
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się dodać tagu");
        }
    }

    private async Task RemoveTag(Tag tag)
    {
        if (_task is null) return;

        try
        {
            var success = await TaskService.RemoveTagFromTaskAsync(_task.Id, tag.Id);
            if (success)
            {
                _task.Tags.RemoveAll(t => t.Id == tag.Id);
                Notify.ShowInfo($"Usunięto tag \"{tag.Name}\"");
            }
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się usunąć tagu");
        }
    }

    private async Task CreateAndAddTag()
    {
        if (_task is null || string.IsNullOrWhiteSpace(_newTagName)) return;

        try
        {
            var tag = await TaskService.CreateTagAsync(_newTagName, _newTagColor);
            _allTags.Add(tag);
            await TaskService.AddTagToTaskAsync(_task.Id, tag.Id);
            if (!_task.Tags.Any(t => t.Id == tag.Id))
                _task.Tags.Add(tag);

            // Reset create form
            _newTagName = string.Empty;
            _newTagColor = "#6366f1";
            _showCreateTag = false;

            Notify.ShowSuccess($"Utworzono i dodano tag \"{tag.Name}\"");
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się utworzyć tagu");
        }
    }

    private void CancelCreateTag()
    {
        _showCreateTag = false;
        _newTagName = string.Empty;
        _newTagColor = "#6366f1";
    }

    // ── Persist & notify ──

    private async Task PersistTask()
    {
        try
        {
            await TaskService.UpdateTaskAsync(_task!);
            Notify.ShowSuccess("Zapisano");
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się zapisać zmian");
        }
    }

    // ── Delete ──

    private async Task HandleDelete()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Usuń zadanie",
            $"Czy na pewno chcesz usunąć zadanie \"{_task?.Title}\"?",
            yesText: "Usuń",
            cancelText: "Anuluj");

        if (confirmed == true)
        {
            try
            {
                await TaskService.DeleteTaskAsync(TaskId);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception)
            {
                Notify.ShowError("Nie udało się usunąć zadania");
            }
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(false));

    // ── Helpers ──

    private static string GetPriorityLabel(Priority priority) => priority switch
    {
        Priority.Low => "Niski",
        Priority.Medium => "Średni",
        Priority.High => "Wysoki",
        Priority.Critical => "Krytyczny",
        _ => priority.ToString()
    };

}
