@using KanbanApp.Services.Interfaces
@inject IBoardService BoardService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Nazwa" Required="true" RequiredError="Nazwa jest wymagana"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="Opis" Lines="3"
                      Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(string.IsNullOrWhiteSpace(_name))">
            Utwórz
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _name = string.Empty;
    private string? _description;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_name))
            return;

        await BoardService.CreateBoardAsync(_name.Trim(), _description?.Trim());
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
