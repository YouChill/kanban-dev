@using KanbanApp.Models
@using KanbanApp.Models.Enums
@using KanbanApp.Services.Interfaces
@inject IColumnService ColumnService
@inject IDialogService DialogService

<div class="kanban-column @WipCssClass" style="border-top: 3px solid @(Column.Color ?? "var(--accent)")">
    <div class="kanban-column__header">
        <span class="kanban-column__dot" style="background-color: @(Column.Color ?? "var(--accent)")"></span>
        <span class="kanban-column__name">@Column.Name</span>
        <span class="kanban-column__badge @WipBadgeCssClass">
            @Column.Tasks.Count
            @if (Column.WipLimit.HasValue)
            {
                <span>/ @Column.WipLimit</span>
            }
        </span>
        <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                 Size="Size.Small"
                 Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 Class="kanban-column__menu">
            <MudMenuItem Icon="@Icons.Material.Outlined.Edit"
                         OnClick="HandleEdit">Edytuj</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Outlined.Delete"
                         OnClick="HandleDelete"
                         Style="color: #ef4444;">Usuń</MudMenuItem>
        </MudMenu>
    </div>

    <MudDropZone T="TaskItem"
                 Identifier="@Column.Id.ToString()"
                 Class="kanban-column__cards"
                 AllowReorder="true" />

    <button class="kanban-column__add-task" @onclick="HandleAddTask">+ Dodaj zadanie</button>
</div>

@code {
    [Parameter, EditorRequired]
    public Column Column { get; set; } = null!;

    [Parameter]
    public EventCallback OnColumnChanged { get; set; }

    private string WipBadgeCssClass => Column.WipLimit switch
    {
        null => "kanban-column__badge--default",
        var limit when Column.Tasks.Count > limit => "kanban-column__badge--exceeded",
        var limit when Column.Tasks.Count == limit => "kanban-column__badge--at-limit",
        _ => "kanban-column__badge--default"
    };

    private string WipCssClass =>
        Column.WipLimit.HasValue && Column.Tasks.Count > Column.WipLimit.Value
            ? "kanban-column--wip-exceeded"
            : "";

    private async Task HandleEdit()
    {
        var parameters = new DialogParameters
        {
            ["ColumnId"] = Column.Id,
            ["Name"] = Column.Name,
            ["ColumnColor"] = Column.Color,
            ["WipLimit"] = Column.WipLimit
        };
        var dialog = await DialogService.ShowAsync<EditColumnDialog>("Edytuj kolumnę", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnColumnChanged.InvokeAsync();
        }
    }

    private async Task HandleDelete()
    {
        var deleted = await ColumnService.DeleteColumnAsync(Column.Id);
        if (deleted)
        {
            await OnColumnChanged.InvokeAsync();
        }
    }

    private async Task HandleAddTask()
    {
        // Add task functionality will be implemented in a future issue (TaskCard)
        await Task.CompletedTask;
    }
}
