@inherits LayoutComponentBase
@using KanbanApp.Models
@using KanbanApp.Components.Board
@using KanbanApp.Components.Shared
@inject IExportService ExportService
@inject IJSRuntime JS
@inject INotificationService Notify

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="this" IsFixed="true">
    <CascadingValue Value="_sidebarCollapsed" Name="SidebarCollapsed">
        <div class="app-layout">
            <Sidebar Collapsed="_sidebarCollapsed" OnToggle="ToggleSidebar" />

            <div class="app-layout__main">
                <TopBar Title="@_pageTitle"
                        BreadcrumbText="@_breadcrumbText"
                        BreadcrumbHref="@_breadcrumbHref">
                    <Actions>
                        @if (_showFilterBar)
                        {
                            <FilterBar AvailableTags="_filterTags" />
                        }
                        @if (_currentBoardId.HasValue)
                        {
                            <MudTooltip Text="Eksportuj">
                            <MudMenu Icon="@Icons.Material.Outlined.FileDownload"
                                     Size="Size.Small"
                                     AnchorOrigin="Origin.BottomRight"
                                     TransformOrigin="Origin.TopRight">
                                <MudMenuItem OnClick="ExportJson"
                                             Icon="@Icons.Material.Outlined.DataObject">
                                    Eksport JSON
                                </MudMenuItem>
                                <MudMenuItem OnClick="ExportCsv"
                                             Icon="@Icons.Material.Outlined.TableChart">
                                    Eksport CSV
                                </MudMenuItem>
                            </MudMenu>
                            </MudTooltip>
                        }
                        @if (_onStatsToggle is not null)
                        {
                            <MudTooltip Text="Statystyki tablicy">
                                <MudIconButton Icon="@Icons.Material.Outlined.BarChart"
                                               Size="Size.Small"
                                               OnClick="HandleStatsToggle" />
                            </MudTooltip>
                        }
                    </Actions>
                </TopBar>

                <main class="app-layout__content">
                    <AppErrorBoundary>
                        @Body
                    </AppErrorBoundary>
                </main>
            </div>
        </div>

        @if (_sidebarCollapsed)
        {
            <button class="sidebar-expand" @onclick="ToggleSidebar" title="Rozwiń sidebar">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>
        }
    </CascadingValue>
</CascadingValue>

@code {
    private bool _sidebarCollapsed;
    private string _pageTitle = "Tablice";
    private string? _breadcrumbText;
    private string? _breadcrumbHref;
    private bool _showFilterBar;
    private List<Tag> _filterTags = [];
    private Action? _onStatsToggle;
    private int? _currentBoardId;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#6366f1",
            Background = "#f1f5f9",
            Surface = "#ffffff",
            AppbarBackground = "#ffffff",
        }
    };

    public void SetPageInfo(string title, string? breadcrumbText = null, string? breadcrumbHref = null)
    {
        _pageTitle = title;
        _breadcrumbText = breadcrumbText;
        _breadcrumbHref = breadcrumbHref;
        _showFilterBar = false;
        _filterTags = [];
        _onStatsToggle = null;
        _currentBoardId = null;
        StateHasChanged();
    }

    public void SetPageInfo(string title, string? breadcrumbText, string? breadcrumbHref, int boardId, List<Tag> availableTags, Action? onStatsToggle = null)
    {
        _pageTitle = title;
        _breadcrumbText = breadcrumbText;
        _breadcrumbHref = breadcrumbHref;
        _showFilterBar = true;
        _filterTags = availableTags;
        _onStatsToggle = onStatsToggle;
        _currentBoardId = boardId;
        StateHasChanged();
    }

    private void HandleStatsToggle()
    {
        _onStatsToggle?.Invoke();
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private async Task ExportJson()
    {
        if (!_currentBoardId.HasValue) return;

        try
        {
            var json = await ExportService.ExportBoardToJsonAsync(_currentBoardId.Value);
            var fileName = $"board-{_currentBoardId.Value}-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            await JS.InvokeVoidAsync("kanbanInterop.downloadFile", fileName, json, "application/json;charset=utf-8");
            Notify.ShowSuccess("Wyeksportowano do JSON");
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się wyeksportować do JSON");
        }
    }

    private async Task ExportCsv()
    {
        if (!_currentBoardId.HasValue) return;

        try
        {
            var csv = await ExportService.ExportTasksToCsvAsync(_currentBoardId.Value);
            var fileName = $"board-{_currentBoardId.Value}-{DateTime.Now:yyyyMMdd-HHmmss}.csv";
            await JS.InvokeVoidAsync("kanbanInterop.downloadFile", fileName, csv, "text/csv;charset=utf-8");
            Notify.ShowSuccess("Wyeksportowano do CSV");
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się wyeksportować do CSV");
        }
    }
}
