@using KanbanApp.Models
@using KanbanApp.Models.Enums

<div class="task-card task-card--@Task.Priority.ToString().ToLower()" @onclick="HandleClick">
    <div class="task-card__header">
        <div class="task-card__title">@Task.Title</div>
        <button class="task-card__delete" @onclick="HandleDelete" @onclick:stopPropagation="true" title="Usuń zadanie">
            <MudIcon Icon="@Icons.Material.Outlined.Close" Size="Size.Small" />
        </button>
    </div>

    @if (Task.Tags.Count > 0)
    {
        <div class="task-card__tags">
            @foreach (var tag in Task.Tags)
            {
                <span class="task-card__tag"
                      style="background-color: @(tag.Color ?? "#6366f1")20; color: @(tag.Color ?? "#6366f1")">
                    @tag.Name
                </span>
            }
        </div>
    }

    <div class="task-card__meta">
        <PriorityBadge Priority="Task.Priority" />

        <div class="task-card__meta-right">
            @if (Task.ChecklistItems.Count > 0)
            {
                var done = Task.ChecklistItems.Count(c => c.IsDone);
                var total = Task.ChecklistItems.Count;
                <span class="task-card__checklist @(done == total ? "task-card__checklist--done" : "")">
                    ✓ @done/@total
                </span>
            }

            @if (Task.DueDate.HasValue)
            {
                var isOverdue = Task.DueDate.Value.Date < DateTime.Today && Task.CompletedAt is null;
                var overdueDays = isOverdue ? (DateTime.Today - Task.DueDate.Value.Date).Days : 0;
                <span class="task-card__due @(isOverdue ? "task-card__due--overdue" : "")"
                      title="@(isOverdue ? $"Termin minął {overdueDays} dni temu" : $"Termin: {Task.DueDate.Value:dd MMM yyyy}")">
                    @if (isOverdue)
                    {
                        <span class="task-card__due-icon">⚠️</span>
                    }
                    @Task.DueDate.Value.ToString("dd MMM")
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TaskItem Task { get; set; } = null!;

    [Parameter]
    public EventCallback<TaskItem> OnClick { get; set; }

    [Parameter]
    public EventCallback<TaskItem> OnDelete { get; set; }

    private async System.Threading.Tasks.Task HandleClick()
    {
        await OnClick.InvokeAsync(Task);
    }

    private async System.Threading.Tasks.Task HandleDelete()
    {
        await OnDelete.InvokeAsync(Task);
    }
}
