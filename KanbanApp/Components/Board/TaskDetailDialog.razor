@using KanbanApp.Models
@using KanbanApp.Models.Enums
@using KanbanApp.Services.Interfaces
@inject ITaskService TaskService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog Class="task-detail-dialog">
    <DialogContent>
        @if (_loading)
        {
            <div class="task-detail__loading">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_task is null)
        {
            <MudText Typo="Typo.body1" Color="Color.Error">Nie znaleziono zadania.</MudText>
        }
        else
        {
            <div class="task-detail__layout">
                <div class="task-detail__left">
                    @if (_editingTitle)
                    {
                        <MudTextField @bind-Value="_titleValue"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      AutoFocus="true"
                                      Class="task-detail__title-input"
                                      OnBlur="SaveTitle"
                                      OnKeyDown="HandleTitleKeyDown" />
                    }
                    else
                    {
                        <MudText Typo="Typo.h5"
                                 Class="task-detail__title task-detail__title--editable"
                                 @onclick="StartEditingTitle">
                            @_task.Title
                        </MudText>
                    }

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Opis</MudText>
                        <MudTextField @bind-Value="_descriptionValue"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Placeholder="Dodaj opis..."
                                      Immediate="true"
                                      DebounceInterval="500"
                                      OnDebounceIntervalElapsed="SaveDescription"
                                      Class="task-detail__description-input" />
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Checklista</MudText>
                        @if (_task.ChecklistItems.Count > 0)
                        {
                            var done = _task.ChecklistItems.Count(c => c.IsDone);
                            var total = _task.ChecklistItems.Count;
                            <MudProgressLinear Value="@((double)done / total * 100)" Color="Color.Primary"
                                              Rounded="true" Size="Size.Small" Class="mb-2" />
                            @foreach (var item in _task.ChecklistItems)
                            {
                                <div class="task-detail__checklist-item">
                                    <MudIcon Icon="@(item.IsDone ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                                             Size="Size.Small"
                                             Color="@(item.IsDone ? Color.Success : Color.Default)" />
                                    <MudText Typo="Typo.body2"
                                             Class="@(item.IsDone ? "task-detail__checklist-done" : "")">
                                        @item.Text
                                    </MudText>
                                </div>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--text-secondary); font-style: italic;">
                                Brak elementów checklisty
                            </MudText>
                        }
                    </div>
                </div>

                <div class="task-detail__right">
                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Priorytet</MudText>
                        <MudSelect T="Priority"
                                   Value="_task.Priority"
                                   ValueChanged="SavePriority"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="task-detail__priority-select">
                            @foreach (Priority p in Enum.GetValues<Priority>())
                            {
                                <MudSelectItem Value="@p">@GetPriorityLabel(p)</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Termin</MudText>
                        <MudDatePicker Date="_dueDateValue"
                                       DateChanged="SaveDueDate"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Placeholder="Wybierz datę..."
                                       Clearable="true"
                                       DateFormat="dd MMMM yyyy"
                                       Class="task-detail__date-picker" />
                    </div>

                    <div class="task-detail__section">
                        <MudText Typo="Typo.caption" Class="task-detail__label">Tagi</MudText>
                        @if (_task.Tags.Count > 0)
                        {
                            <div class="task-detail__tags">
                                @foreach (var tag in _task.Tags)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Style="@($"background-color: {(tag.Color ?? "#6366f1")}20; color: {(tag.Color ?? "#6366f1")}; font-weight: 600;")">
                                        @tag.Name
                                    </MudChip>
                                }
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--text-secondary); font-style: italic;">
                                Brak tagów
                            </MudText>
                        }
                    </div>

                    <div class="task-detail__divider"></div>

                    <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                               StartIcon="@Icons.Material.Outlined.Delete" OnClick="HandleDelete">
                        Usuń zadanie
                    </MudButton>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Zamknij</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int TaskId { get; set; }

    private TaskItem? _task;
    private bool _loading = true;

    // Editable field state
    private bool _editingTitle;
    private string _titleValue = string.Empty;
    private string? _descriptionValue;
    private DateTime? _dueDateValue;

    protected override async Task OnInitializedAsync()
    {
        _task = await TaskService.GetTaskByIdAsync(TaskId);
        if (_task is not null)
        {
            _titleValue = _task.Title;
            _descriptionValue = _task.Description;
            _dueDateValue = _task.DueDate;
        }
        _loading = false;
    }

    // ── Title editing ──

    private void StartEditingTitle()
    {
        _titleValue = _task!.Title;
        _editingTitle = true;
    }

    private async Task SaveTitle()
    {
        _editingTitle = false;
        if (_task is null) return;

        var trimmed = _titleValue?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || trimmed == _task.Title)
        {
            _titleValue = _task.Title;
            return;
        }

        _task.Title = trimmed;
        _titleValue = trimmed;
        await PersistTask();
    }

    private async Task HandleTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveTitle();
        }
        else if (e.Key == "Escape")
        {
            _titleValue = _task!.Title;
            _editingTitle = false;
        }
    }

    // ── Description editing (debounced) ──

    private async Task SaveDescription(string value)
    {
        if (_task is null) return;
        _task.Description = value;
        await PersistTask();
    }

    // ── Priority editing ──

    private async Task SavePriority(Priority newPriority)
    {
        if (_task is null || _task.Priority == newPriority) return;
        _task.Priority = newPriority;
        await PersistTask();
    }

    // ── Due date editing ──

    private async Task SaveDueDate(DateTime? newDate)
    {
        if (_task is null) return;
        _dueDateValue = newDate;
        _task.DueDate = newDate;
        await PersistTask();
    }

    // ── Persist & notify ──

    private async Task PersistTask()
    {
        await TaskService.UpdateTaskAsync(_task!);
        Snackbar.Add("Zapisano", Severity.Success, config =>
        {
            config.ShowTransitionDuration = 200;
            config.HideTransitionDuration = 200;
            config.VisibleStateDuration = 1500;
        });
    }

    // ── Delete ──

    private async Task HandleDelete()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Usuń zadanie",
            $"Czy na pewno chcesz usunąć zadanie \"{_task?.Title}\"?",
            yesText: "Usuń",
            cancelText: "Anuluj");

        if (confirmed == true)
        {
            await TaskService.DeleteTaskAsync(TaskId);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(false));

    // ── Helpers ──

    private static string GetPriorityLabel(Priority priority) => priority switch
    {
        Priority.Low => "Niski",
        Priority.Medium => "Średni",
        Priority.High => "Wysoki",
        Priority.Critical => "Krytyczny",
        _ => priority.ToString()
    };

}
