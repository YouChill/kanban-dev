@using KanbanApp.Services.Interfaces
@inject IColumnService ColumnService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Nazwa" Required="true" RequiredError="Nazwa jest wymagana"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_color" Label="Kolor (hex)" Placeholder="#6366f1"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudNumericField @bind-Value="_wipLimit" Label="Limit WIP" Min="1"
                         Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(string.IsNullOrWhiteSpace(_name))">
            Zapisz
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int ColumnId { get; set; }

    [Parameter]
    public string Name { get; set; } = string.Empty;

    [Parameter]
    public string? ColumnColor { get; set; }

    [Parameter]
    public int? WipLimit { get; set; }

    private string _name = string.Empty;
    private string? _color;
    private int? _wipLimit;

    protected override void OnInitialized()
    {
        _name = Name;
        _color = ColumnColor;
        _wipLimit = WipLimit;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_name))
            return;

        var color = string.IsNullOrWhiteSpace(_color) ? null : _color.Trim();
        await ColumnService.UpdateColumnAsync(ColumnId, _name.Trim(), color, _wipLimit);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
