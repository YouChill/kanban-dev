@page "/boards"
@using KanbanApp.Models
@using KanbanApp.Services.Interfaces
@inject IBoardService BoardService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject INotificationService Notify

<PageTitle>Tablice</PageTitle>

@if (_loading)
{
    <div class="boards-loading">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Ładowanie tablic...</MudText>
    </div>
}
else if (_error)
{
    <div class="boards-empty">
        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline"
                 Style="font-size: 80px; color: #ef4444; opacity: 0.6;" />
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-4">Błąd ładowania</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Nie udało się załadować tablic. Spróbuj ponownie.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadBoards">
            Spróbuj ponownie
        </MudButton>
    </div>
}
else if (_boards is null || _boards.Count == 0)
{
    <div class="boards-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Style="font-size: 80px; color: var(--text-secondary); opacity: 0.4;" />
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-4">Nie masz jeszcze żadnej tablicy</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Utwórz pierwszą tablicę, aby rozpocząć pracę</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewBoardDialog">
            Nowa tablica
        </MudButton>
    </div>
}
else
{
    <div class="boards-header">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewBoardDialog">
            Nowa tablica
        </MudButton>
    </div>

    <MudGrid Class="mt-4">
        @foreach (var board in _boards)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="boards-card" Elevation="0">
                    <MudCardContent>
                        <div class="boards-card__header">
                            <div class="boards-card__title-area">
                                @if (_renamingBoardId == board.Id)
                                {
                                    <MudTextField @bind-Value="_renameValue"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  AutoFocus="true"
                                                  OnBlur="() => SaveRename(board)"
                                                  OnKeyDown="(e) => OnRenameKeyDown(e, board)"
                                                  Immediate="true" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.h6">@board.Name</MudText>
                                }
                            </div>
                            <div class="boards-card__menu">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                         Size="Size.Small"
                                         AnchorOrigin="Origin.BottomRight"
                                         TransformOrigin="Origin.TopRight"
                                         Dense="true">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                                 OnClick="() => StartRename(board)">
                                        Zmień nazwę
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                                 IconColor="Color.Error"
                                                 OnClick="() => OpenDeleteDialog(board)">
                                        Usuń
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(board.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2 boards-card__description">
                                @Truncate(board.Description, 100)
                            </MudText>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
                            Utworzono: @board.CreatedAt.ToString("dd.MM.yyyy")
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="() => OpenBoard(board.Id)">
                            Otwórz
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<Board>? _boards;
    private bool _loading = true;
    private bool _error;

    private int? _renamingBoardId;
    private string _renameValue = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadBoards();
    }

    private async Task LoadBoards()
    {
        _loading = true;
        _error = false;

        try
        {
            _boards = await BoardService.GetAllBoardsAsync();
        }
        catch (Exception)
        {
            _boards = null;
            _error = true;
            Notify.ShowError("Nie udało się załadować tablic");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenNewBoardDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NewBoardDialog>("Nowa tablica", options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadBoards();
        }
    }

    private void OpenBoard(int id)
    {
        Navigation.NavigateTo($"/board/{id}");
    }

    // ===== Rename =====

    private void StartRename(Board board)
    {
        _renamingBoardId = board.Id;
        _renameValue = board.Name;
    }

    private async Task SaveRename(Board board)
    {
        if (_renamingBoardId != board.Id)
            return;

        _renamingBoardId = null;

        var newName = _renameValue.Trim();
        if (string.IsNullOrWhiteSpace(newName) || newName == board.Name)
            return;

        try
        {
            var updated = await BoardService.UpdateBoardAsync(board.Id, newName, board.Description);
            if (updated is not null)
            {
                board.Name = updated.Name;
                Notify.ShowSuccess("Nazwa tablicy zaktualizowana");
            }
        }
        catch (Exception)
        {
            Notify.ShowError("Nie udało się zmienić nazwy tablicy");
        }
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e, Board board)
    {
        if (e.Key == "Enter")
        {
            await SaveRename(board);
        }
        else if (e.Key == "Escape")
        {
            _renamingBoardId = null;
        }
    }

    // ===== Delete =====

    private async Task OpenDeleteDialog(Board board)
    {
        var parameters = new DialogParameters<DeleteBoardDialog>
        {
            { x => x.BoardId, board.Id },
            { x => x.BoardName, board.Name }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeleteBoardDialog>("Usuń tablicę", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Notify.ShowSuccess("Tablica usunięta");
            await LoadBoards();
        }
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }
}
