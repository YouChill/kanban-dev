@using KanbanApp.Models
@using KanbanApp.Models.Enums
@using KanbanApp.Services
@using KanbanApp.Services.Interfaces
@inject IColumnService ColumnService
@inject ITaskService TaskService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject INotificationService Notify
@inject IJSRuntime JS
@inject BoardFilterState FilterState

<div class="kanban-column @WipCssClass" style="border-top: 3px solid @(Column.Color ?? "var(--accent)")">
    <div class="kanban-column__header">
        <span class="kanban-column__dot" style="background-color: @(Column.Color ?? "var(--accent)")"></span>
        <span class="kanban-column__name">@Column.Name</span>
        <span class="kanban-column__badge @WipBadgeCssClass">
            @Column.Tasks.Count
            @if (Column.WipLimit.HasValue)
            {
                <span>/ @Column.WipLimit</span>
            }
        </span>
        <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                 Size="Size.Small"
                 Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 Class="kanban-column__menu">
            <MudMenuItem Icon="@Icons.Material.Outlined.Edit"
                         OnClick="HandleEdit">Edytuj</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Outlined.Delete"
                         OnClick="HandleDelete"
                         Style="color: #ef4444;">Usuń</MudMenuItem>
        </MudMenu>
    </div>

    <MudDropZone T="TaskItem"
                 Identifier="@Column.Id.ToString()"
                 CanDropClass="kanban-column__cards--drop-ready"
                 Class="kanban-column__cards">
        @if (Column.Tasks.Count == 0)
        {
            <div class="kanban-empty-state">
                <MudIcon Icon="@Icons.Material.Outlined.Add" Class="kanban-empty-state__icon" />
                <span class="kanban-empty-state__text">Przeciągnij tutaj zadanie lub dodaj nowe</span>
            </div>
        }
        else if (FilteredTaskCount == 0)
        {
            <div class="kanban-empty-state">
                <MudIcon Icon="@Icons.Material.Outlined.FilterList" Class="kanban-empty-state__icon" />
                <span class="kanban-empty-state__text">Żadne zadanie nie pasuje do filtrów</span>
            </div>
        }
    </MudDropZone>

    <div class="kanban-column__footer">
        @if (_isAddingTask)
        {
            <div class="kanban-column__inline-input kanban-column__inline-input--active">
                <MudTextField @bind-Value="_newTaskTitle"
                              Placeholder="Tytuł zadania..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              AutoFocus="true"
                              OnKeyDown="HandleTaskInputKeyDown"
                              Immediate="true"
                              Class="kanban-column__task-field" />
            </div>
        }
        else
        {
            <button class="kanban-column__add-task" @onclick="ShowTaskInput">+ Dodaj zadanie</button>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Column Column { get; set; } = null!;

    [Parameter]
    public EventCallback OnColumnChanged { get; set; }

    private bool _isAddingTask;
    private string _newTaskTitle = string.Empty;
    private bool _scrollToNewTask;

    private int FilteredTaskCount => Column.Tasks.Count(t => FilterState.Matches(t));

    private string WipBadgeCssClass => Column.WipLimit switch
    {
        null => "kanban-column__badge--default",
        var limit when Column.Tasks.Count > limit => "kanban-column__badge--exceeded",
        var limit when Column.Tasks.Count == limit => "kanban-column__badge--at-limit",
        _ => "kanban-column__badge--default"
    };

    private string WipCssClass =>
        Column.WipLimit.HasValue && Column.Tasks.Count > Column.WipLimit.Value
            ? "kanban-column--wip-exceeded"
            : "";

    private static readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        BackdropClick = true
    };

    private async Task HandleEdit()
    {
        var parameters = new DialogParameters
        {
            ["ExistingColumn"] = Column
        };
        var dialog = await DialogService.ShowAsync<AddColumnDialog>("Edytuj kolumnę", parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnColumnChanged.InvokeAsync();
        }
    }

    private async Task HandleDelete()
    {
        var parameters = new DialogParameters
        {
            ["ColumnId"] = Column.Id
        };
        var dialog = await DialogService.ShowAsync<DeleteColumnDialog>("Usuń kolumnę", parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnColumnChanged.InvokeAsync();
        }
    }

    private async Task ShowTaskInput()
    {
        if (!await TaskService.CanMoveToColumnAsync(Column.Id))
        {
            Snackbar.Add("Kolumna osiągnęła limit WIP — nie można dodać zadania", Severity.Warning);
            return;
        }

        _isAddingTask = true;
        _newTaskTitle = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollToNewTask)
        {
            _scrollToNewTask = false;
            await JS.InvokeVoidAsync("kanbanInterop.scrollToLastCard", Column.Id.ToString());
        }
    }

    private async Task HandleTaskInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newTaskTitle))
        {
            try
            {
                await TaskService.CreateTaskAsync(Column.Id, _newTaskTitle.Trim(), Priority.Medium);
                _newTaskTitle = string.Empty;
                _isAddingTask = false;
                _scrollToNewTask = true;
                await OnColumnChanged.InvokeAsync();
            }
            catch (Exception)
            {
                Notify.ShowError("Nie udało się utworzyć zadania");
            }
        }
        else if (e.Key == "Escape")
        {
            _isAddingTask = false;
            _newTaskTitle = string.Empty;
        }
    }
}
