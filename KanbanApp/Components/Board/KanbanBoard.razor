@using KanbanApp.Models
@using KanbanApp.Services.Interfaces
@inject IDialogService DialogService
@inject ITaskService TaskService
@inject ISnackbar Snackbar

<MudDropContainer T="TaskItem"
                  Items="_allTasks"
                  ItemsSelector="@((task, zone) => task.ColumnId.ToString() == zone)"
                  ItemDropped="OnItemDropped"
                  Class="kanban-board">
    <ChildContent>
        @foreach (var column in Columns.OrderBy(c => c.Order))
        {
            <KanbanColumn Column="column" OnColumnChanged="OnColumnChanged" />
        }

        <div class="kanban-add-column">
            <button class="kanban-add-column__btn" @onclick="OpenNewColumnDialog">+ Dodaj kolumnę</button>
        </div>
    </ChildContent>
    <ItemRenderer>
        <TaskCard Task="context" />
    </ItemRenderer>
</MudDropContainer>

@code {
    [Parameter, EditorRequired]
    public List<Column> Columns { get; set; } = [];

    [Parameter]
    public int BoardId { get; set; }

    [Parameter]
    public EventCallback OnColumnChanged { get; set; }

    private List<TaskItem> _allTasks = [];

    protected override void OnParametersSet()
    {
        _allTasks = Columns.SelectMany(c => c.Tasks).OrderBy(t => t.Order).ToList();
    }

    private async Task OnItemDropped(MudItemDropInfo<TaskItem> info)
    {
        var task = info.Item;
        var targetColumnId = int.Parse(info.DropzoneIdentifier);
        var newOrder = info.IndexInZone;

        // Optimistic UI update
        task.ColumnId = targetColumnId;
        task.Order = newOrder;

        var success = await TaskService.MoveTaskAsync(task.Id, targetColumnId, newOrder);
        if (!success)
        {
            Snackbar.Add("Nie udało się przenieść zadania — przekroczony limit WIP", Severity.Warning);
        }

        await OnColumnChanged.InvokeAsync();
    }

    private async Task OpenNewColumnDialog()
    {
        var parameters = new DialogParameters { ["BoardId"] = BoardId };
        var dialog = await DialogService.ShowAsync<NewColumnDialog>("Nowa kolumna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnColumnChanged.InvokeAsync();
        }
    }
}
