@using KanbanApp.Models
@using KanbanApp.Services
@using KanbanApp.Services.Interfaces
@implements IAsyncDisposable
@inject IDialogService DialogService
@inject ITaskService TaskService
@inject ISnackbar Snackbar
@inject BoardFilterState FilterState
@inject IJSRuntime JS

@if (Columns.Count == 0)
{
    <div class="kanban-board-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Class="kanban-board-empty__icon" />
        <MudText Typo="Typo.h6" Class="kanban-board-empty__title">Brak kolumn</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="kanban-board-empty__text">
            Dodaj pierwszą kolumnę, aby rozpocząć
        </MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenNewColumnDialog"
                   StartIcon="@Icons.Material.Filled.Add" Class="mt-4">
            Dodaj kolumnę
        </MudButton>
    </div>
}
else
{
    <MudDropContainer @ref="_dropContainer"
                      T="TaskItem"
                      Items="AllTasks"
                      ItemsSelector="@((item, zone) => item.ColumnId.ToString() == zone)"
                      ItemDropped="OnTaskDropped"
                      DraggingClass="task-card--dragging"
                      Class="kanban-board">
        <ChildContent>
            @foreach (var column in Columns.OrderBy(c => c.Order))
            {
                <KanbanColumn Column="column" OnColumnChanged="HandleColumnChanged" />
            }

            <div class="kanban-add-column">
                <button class="kanban-add-column__btn" @onclick="OpenNewColumnDialog">+ Dodaj kolumnę</button>
            </div>
        </ChildContent>
        <ItemRenderer>
            <TaskCard Task="@context" OnClick="HandleTaskClick" OnDelete="HandleTaskDelete" />
        </ItemRenderer>
    </MudDropContainer>
}

@code {
    [Parameter, EditorRequired]
    public List<Column> Columns { get; set; } = [];

    [Parameter]
    public int BoardId { get; set; }

    [Parameter]
    public EventCallback OnColumnChanged { get; set; }

    private MudDropContainer<TaskItem>? _dropContainer;
    private bool _shortcutsRegistered;

    private List<TaskItem> AllTasks =>
        Columns.SelectMany(c => c.Tasks)
            .Where(t => FilterState.Matches(t))
            .OrderBy(t => t.Order)
            .ToList();

    protected override void OnInitialized()
    {
        FilterState.OnFilterChanged += HandleFilterChanged;
    }

    protected override void OnParametersSet()
    {
        _dropContainer?.Refresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_shortcutsRegistered)
        {
            _shortcutsRegistered = true;
            await RegisterKeyboardShortcuts();
        }
        if (_filterDirty)
        {
            _filterDirty = false;
            _dropContainer?.Refresh();
        }
    }

    private bool _filterDirty;

    private void HandleFilterChanged()
    {
        _filterDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task RegisterKeyboardShortcuts()
    {
        await JS.InvokeVoidAsync("eval", @"
            if (!window._kanbanShortcutHandler) {
                window._kanbanShortcutHandler = function(e) {
                    var tag = e.target.tagName;
                    if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target.isContentEditable) return;
                    if (e.target.closest('.mud-dialog-container')) return;
                    if ((e.key === 'n' || e.key === 'N') && !e.ctrlKey && !e.altKey && !e.metaKey) {
                        e.preventDefault();
                        window.kanbanInterop.focusFirstAddTask();
                    }
                };
                document.addEventListener('keydown', window._kanbanShortcutHandler);
            }
        ");
    }

    private async Task UnregisterKeyboardShortcuts()
    {
        await JS.InvokeVoidAsync("eval", @"
            if (window._kanbanShortcutHandler) {
                document.removeEventListener('keydown', window._kanbanShortcutHandler);
                window._kanbanShortcutHandler = null;
            }
        ");
    }

    public async ValueTask DisposeAsync()
    {
        FilterState.OnFilterChanged -= HandleFilterChanged;
        try
        {
            await UnregisterKeyboardShortcuts();
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, ignore
        }
    }

    private async Task HandleColumnChanged()
    {
        await OnColumnChanged.InvokeAsync();
    }

    private async Task OnTaskDropped(MudItemDropInfo<TaskItem> dropItem)
    {
        if (dropItem.Item is null) return;

        var targetColumnId = int.Parse(dropItem.DropzoneIdentifier);
        var movingAcrossColumns = dropItem.Item.ColumnId != targetColumnId;

        if (movingAcrossColumns && !await TaskService.CanMoveToColumnAsync(targetColumnId))
        {
            Snackbar.Add("Kolumna osiągnęła limit WIP", Severity.Warning);
            return;
        }

        // Update local state for immediate UI feedback
        dropItem.Item.ColumnId = targetColumnId;
        dropItem.Item.Order = dropItem.IndexInZone;

        // Persist to database
        await TaskService.MoveTaskAsync(dropItem.Item.Id, targetColumnId, dropItem.IndexInZone);

        // Reload to sync full state
        await HandleColumnChanged();
    }

    private async Task HandleTaskClick(TaskItem task)
    {
        var parameters = new DialogParameters { ["TaskId"] = task.Id };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
            BackdropClick = true
        };
        var dialog = await DialogService.ShowAsync<TaskDetailDialog>(task.Title, parameters, options);
        var result = await dialog.Result;

        // Refresh board after dialog closes (handles deletion or future edits)
        await HandleColumnChanged();
    }

    private async Task HandleTaskDelete(TaskItem task)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Usuń zadanie",
            $"Czy na pewno chcesz usunąć zadanie \"{task.Title}\"?",
            yesText: "Usuń",
            cancelText: "Anuluj");

        if (confirmed == true)
        {
            await TaskService.DeleteTaskAsync(task.Id);
            await HandleColumnChanged();
        }
    }

    private static readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        BackdropClick = true
    };

    private async Task OpenNewColumnDialog()
    {
        var parameters = new DialogParameters { ["BoardId"] = BoardId };
        var dialog = await DialogService.ShowAsync<AddColumnDialog>("Nowa kolumna", parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await HandleColumnChanged();
        }
    }
}
