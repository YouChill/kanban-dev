@page "/board/{Id:int}"
@using KanbanApp.Models
@using KanbanApp.Services
@using KanbanApp.Services.Interfaces
@using KanbanApp.Components.Layout
@using KanbanApp.Components.Board
@inject IBoardService BoardService
@inject BoardFilterState FilterState
@inject NavigationManager Navigation
@inject INotificationService Notify
@implements IDisposable

<PageTitle>@(_board?.Name ?? "Tablica") – KanbanApp</PageTitle>

@if (_loading)
{
    <div class="boards-loading">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Ładowanie tablicy...</MudText>
    </div>
}
else if (_error)
{
    <div class="boards-empty">
        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline"
                 Style="font-size: 80px; color: #ef4444; opacity: 0.6;" />
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-4">Błąd ładowania tablicy</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Nie udało się załadować danych. Spróbuj ponownie.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadBoard">
            Spróbuj ponownie
        </MudButton>
    </div>
}
else if (_board is null)
{
    <div class="boards-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Dashboard"
                 Style="font-size: 80px; color: var(--text-secondary); opacity: 0.4;" />
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-4">Tablica nie istnieje</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Tablica o podanym identyfikatorze nie została znaleziona.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToBoards">
            Wróć do tablic
        </MudButton>
    </div>
}
else
{
    <KanbanBoard Columns="_board.Columns" BoardId="_board.Id" OnColumnChanged="LoadBoard" />
    <BoardStatisticsPanel @bind-IsOpen="_statsOpen" Columns="_board.Columns" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    [CascadingParameter]
    private MainLayout? Layout { get; set; }

    private Board? _board;
    private bool _loading = true;
    private bool _error;
    private bool _statsOpen;
    private int _lastLoadedId = -1;

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _lastLoadedId)
        {
            _lastLoadedId = Id;
            await LoadBoard();
        }
    }

    private async Task LoadBoard()
    {
        _loading = true;
        _error = false;

        try
        {
            _board = await BoardService.GetBoardByIdAsync(Id);
        }
        catch (Exception)
        {
            _board = null;
            _error = true;
            Notify.ShowError("Nie udało się załadować tablicy");
        }
        finally
        {
            _loading = false;
        }

        if (_board is not null)
        {
            var availableTags = _board.Columns
                .SelectMany(c => c.Tasks)
                .SelectMany(t => t.Tags)
                .GroupBy(t => t.Id)
                .Select(g => g.First())
                .OrderBy(t => t.Name)
                .ToList();
            Layout?.SetPageInfo(_board.Name, "Tablice", "/boards", _board.Id, availableTags, ToggleStats);
        }
        else if (!_error)
        {
            Layout?.SetPageInfo("Tablica nie znaleziona");
        }
    }

    private void ToggleStats()
    {
        _statsOpen = !_statsOpen;
        StateHasChanged();
    }

    private void GoToBoards()
    {
        Navigation.NavigateTo("/boards");
    }

    public void Dispose()
    {
        FilterState.ClearAll();
        Layout?.SetPageInfo("Tablice");
    }
}
