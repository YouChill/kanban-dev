@inherits LayoutComponentBase
@using KanbanApp.Models
@using KanbanApp.Components.Board

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="this" IsFixed="true">
    <CascadingValue Value="_sidebarCollapsed" Name="SidebarCollapsed">
        <div class="app-layout">
            <Sidebar Collapsed="_sidebarCollapsed" OnToggle="ToggleSidebar" />

            <div class="app-layout__main">
                <TopBar Title="@_pageTitle"
                        BreadcrumbText="@_breadcrumbText"
                        BreadcrumbHref="@_breadcrumbHref"
                        Actions="@_topBarActions" />

                <main class="app-layout__content">
                    @Body
                </main>
            </div>
        </div>

        @if (_sidebarCollapsed)
        {
            <button class="sidebar-expand" @onclick="ToggleSidebar" title="Rozwiń sidebar">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>
        }
    </CascadingValue>
</CascadingValue>

@code {
    private bool _sidebarCollapsed;
    private string _pageTitle = "Tablice";
    private string? _breadcrumbText;
    private string? _breadcrumbHref;
    private RenderFragment? _topBarActions;
    private List<Tag> _filterTags = [];

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#6366f1",
            Background = "#f1f5f9",
            Surface = "#ffffff",
            AppbarBackground = "#ffffff",
        }
    };

    public void SetPageInfo(string title, string? breadcrumbText = null, string? breadcrumbHref = null)
    {
        _pageTitle = title;
        _breadcrumbText = breadcrumbText;
        _breadcrumbHref = breadcrumbHref;
        _topBarActions = null;
        _filterTags = [];
        StateHasChanged();
    }

    public void SetPageInfo(string title, string? breadcrumbText, string? breadcrumbHref, List<Tag> availableTags, Action? onStatsToggle = null)
    {
        _pageTitle = title;
        _breadcrumbText = breadcrumbText;
        _breadcrumbHref = breadcrumbHref;
        _filterTags = availableTags;
        _topBarActions = builder =>
        {
            builder.OpenComponent<FilterBar>(0);
            builder.AddAttribute(1, nameof(FilterBar.AvailableTags), _filterTags);
            builder.CloseComponent();

            if (onStatsToggle is not null)
            {
                builder.OpenComponent<MudIconButton>(2);
                builder.AddAttribute(3, nameof(MudIconButton.Icon), Icons.Material.Outlined.BarChart);
                builder.AddAttribute(4, nameof(MudIconButton.Size), Size.Small);
                builder.AddAttribute(5, nameof(MudIconButton.Title), "Statystyki tablicy");
                builder.AddAttribute(6, nameof(MudIconButton.OnClick),
                    EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, onStatsToggle));
                builder.CloseComponent();
            }
        };
        StateHasChanged();
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
